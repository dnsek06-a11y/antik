# === Domény (pro Caddy reverse proxy) ===
DOMAIN_STOREFRONT=eshop.example.cz
DOMAIN_BACKEND=admin.eshop.example.cz
ACME_EMAIL=you@example.cz

# === PostgreSQL ===
POSTGRES_USER=medusa
POSTGRES_PASSWORD=changeme_postgres
POSTGRES_DB=medusa
DATABASE_URL=postgres://medusa:changeme_postgres@postgres:5432/medusa

# === Redis ===
REDIS_URL=redis://redis:6379

# === Meilisearch ===
MEILI_MASTER_KEY=changeme_meili_master_key_min_16_chars
MEILISEARCH_HOST=http://meilisearch:7700

# === MinIO (S3-kompatibilní storage pro fotky) ===
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=changeme_minio_password
MINIO_BUCKET=antikvariat-media
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY_ID=minio_admin
S3_SECRET_ACCESS_KEY=changeme_minio_password
S3_BUCKET=antikvariat-media
S3_REGION=eu-central-1

# === Medusa backend ===
JWT_SECRET=changeme_generate_random_string
COOKIE_SECRET=changeme_generate_random_string
STORE_CORS=https://eshop.example.cz
ADMIN_CORS=https://admin.eshop.example.cz
AUTH_CORS=https://eshop.example.cz,https://admin.eshop.example.cz
MEDUSA_BACKEND_URL=https://admin.eshop.example.cz

# === Next.js storefront ===
NEXT_PUBLIC_MEDUSA_BACKEND_URL=https://admin.eshop.example.cz
NEXT_PUBLIC_BASE_URL=https://eshop.example.cz
NEXT_PUBLIC_DEFAULT_REGION=cz
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=changeme_after_admin_setup

# === Platby (Comgate - viz backend/apps/backend/src/modules/comgate) ===
COMGATE_MERCHANT_ID=
COMGATE_SECRET=
# false teprve až po ověření na produkčním merchant účtu
COMGATE_TEST_MODE=true
# stejná hodnota jako NEXT_PUBLIC_BASE_URL - použije backend pro Comgate return URL
STOREFRONT_URL=https://eshop.example.cz
GOPAY_GOID=
GOPAY_CLIENT_ID=
GOPAY_CLIENT_SECRET=

# === Doprava (Packeta/Zásilkovna - viz backend/apps/backend/src/modules/packeta) ===
PACKETA_API_KEY=
PACKETA_ESHOP_ID=

# === Externí API ===
DISCOGS_TOKEN=
GOOGLE_BOOKS_API_KEY=

# === Zálohy (Backblaze B2) ===
B2_APPLICATION_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET=
